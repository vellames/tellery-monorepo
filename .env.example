OPENROUTER_API_KEY=
WAVESPEED_API_KEY=
# ElevenLabs — required by apps/creative-video-generator for the voiceover step.
# Get your API key at https://elevenlabs.io/app/settings/api-keys.
# ELEVENLABS_VOICE_ID is optional; if unset, the creative-video-generator falls
# back to a default English voice. Set it to a pt-BR voice from your library.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
PORT=3232
NODE_ENV=development
CORS_ORIGIN=*

DATABASE_URL=postgresql://postgres:postgres@localhost:5555/ai_history?schema=public
DB_PORT=5555
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_history

OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_INTENT_MODEL=google/gemini-2.5-flash
OPENROUTER_OBJECT_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_CHARACTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_REASONING_EFFORT=medium
INTENT_DETECTOR_THRESHOLD=0.5
DEFAULT_LANGUAGE=pt-BR

BCRYPT_SALT_ROUNDS=10

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PRESIGNED_EXPIRATION_SECONDS=604800

VALIDATOR_EMAIL=
VALIDATOR_PASSWORD=
VALIDATOR_HISTORY_SLUG=o-bilhete-na-mesa-7
VALIDATOR_API_URL=http://localhost:3232
VALIDATOR_INVESTIGATOR_MODEL=deepseek/deepseek-v4-pro
VALIDATOR_MAX_ITERATIONS=50
VALIDATOR_OUTPUT=validator-output.txt

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Email (Resend) — get the API key at https://resend.com/api-keys
# EMAIL_FROM must be an address on a domain verified in your Resend dashboard.
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Tellery
