generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum HistoryStatus {
  draft
  published
  archived
}

enum ClueImportance {
  required
  supporting
  red_herring
}

enum ConclusionFieldType {
  character
  choice
}

enum EndingType {
  full_truth
  partial_truth
  wrong_accusation
}

enum SecretDefaultStrategy {
  deny
  avoid
  deflect
  cover_story
  justify
}

enum HistorySessionStatus {
  active
  completed
  abandoned
}

enum InteractionRole {
  user
  character
  object
  system
}

enum LlmCallPurpose {
  intent
  character
  object
  audio
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  name     String
  email    String @unique
  password String
  ssn      String?

  availableCredits Int @default(3)

  sessions     HistorySession[]
  subscription Subscription?
}

// ─── History (authored content) ───────────────────────────────────────────────

model History {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  slug String @unique

  title    String
  subtitle String?
  teaser   String

  genre String

  estimatedDurationMinutes Int
  status                   HistoryStatus @default(draft)
  isFeatured               Boolean       @default(false)
  isFree                   Boolean       @default(false)

  coverImageUrl String?
  thumbnailUrl  String?

  opening   String
  objective String

  publishedAt DateTime?

  intentDefinitions IntentDefinition[]
  characters        CharacterDefinition[]
  locations         LocationDefinition[]
  objects           ObjectDefinition[]
  clues             ClueDefinition[]
  conclusion        ConclusionDefinition?
  endings           EndingDefinition[]
}

model IntentDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  description String
  examples    String[] @default([])
  keywords    String[] @default([])

  triggerIntentsForCharacterRules CharacterClueRevealRule[] @relation("CharacterRevealRuleTriggerIntents")
  triggerIntentsForObjectRules    ObjectClueRevealRule[]    @relation("ObjectRevealRuleTriggerIntents")
  triggerIntentsForSecretStages   SecretRevealStage[]       @relation("SecretStageTriggerIntents")

  @@index([historyId])
}

model CharacterDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  name             String
  role             String
  shortDescription String

  imageUrl String?

  personality   String
  speakingStyle String

  publicKnowledge        String[] @default([])
  privateKnowledge       String[] @default([])
  conversationBoundaries String[] @default([])

  openingLine String

  clueRevealRules CharacterClueRevealRule[]
  secrets         CharacterSecret[]

  @@index([historyId])
}

model CharacterClueRevealRule {
  id String @id @default(uuid())

  characterId String
  character   CharacterDefinition @relation(fields: [characterId], references: [id], onDelete: Cascade)

  clueId String
  clue   ClueDefinition @relation("CharacterRevealRuleClue", fields: [clueId], references: [id], onDelete: Cascade)

  triggerIntents IntentDefinition[] @relation("CharacterRevealRuleTriggerIntents")
  requiredClues  ClueDefinition[]   @relation("CharacterRevealRuleRequiredClues")

  revealText       String
  responseGuidance String

  @@index([characterId])
  @@index([clueId])
}

model CharacterSecret {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  characterId String
  character   CharacterDefinition @relation(fields: [characterId], references: [id], onDelete: Cascade)

  summary String
  truth   String

  defaultStrategy SecretDefaultStrategy

  revealStages SecretRevealStage[]

  @@index([characterId])
}

model SecretRevealStage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  secretId String
  secret   CharacterSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)

  level Int

  triggerIntents IntentDefinition[] @relation("SecretStageTriggerIntents")
  requiredClues  ClueDefinition[]   @relation("SecretStageRequiredClues")
  revealedClues  ClueDefinition[]   @relation("SecretStageRevealedClues")

  behavior             String
  allowedToRevealTruth Boolean

  sampleResponses String[] @default([])

  @@index([secretId])
}

model LocationDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  name             String
  shortDescription String

  imageUrl String?

  initialDescription String

  ambientClues ClueDefinition[] @relation("LocationAmbientClues")

  objects ObjectDefinition[]

  @@index([historyId])
}

model ObjectDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  locationId String
  location   LocationDefinition @relation(fields: [locationId], references: [id], onDelete: Cascade)

  name             String
  shortDescription String

  imageUrl String?

  initialDescription String

  clueRevealRules ObjectClueRevealRule[]

  @@index([historyId])
  @@index([locationId])
}

model ObjectClueRevealRule {
  id String @id @default(uuid())

  objectId String
  object   ObjectDefinition @relation(fields: [objectId], references: [id], onDelete: Cascade)

  clueId String
  clue   ClueDefinition @relation("ObjectRevealRuleClue", fields: [clueId], references: [id], onDelete: Cascade)

  triggerIntents IntentDefinition[] @relation("ObjectRevealRuleTriggerIntents")
  requiredClues  ClueDefinition[]   @relation("ObjectRevealRuleRequiredClues")

  revealText String

  @@index([objectId])
  @@index([clueId])
}

model ClueDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  title       String
  description String

  importance ClueImportance

  characterRevealRules CharacterClueRevealRule[] @relation("CharacterRevealRuleClue")
  objectRevealRules    ObjectClueRevealRule[]    @relation("ObjectRevealRuleClue")

  requiredByCharacterRules CharacterClueRevealRule[] @relation("CharacterRevealRuleRequiredClues")
  requiredByObjectRules    ObjectClueRevealRule[]    @relation("ObjectRevealRuleRequiredClues")

  requiredBySecretStages SecretRevealStage[] @relation("SecretStageRequiredClues")
  revealedBySecretStages SecretRevealStage[] @relation("SecretStageRevealedClues")

  ambientInLocations LocationDefinition[] @relation("LocationAmbientClues")
  requiredByEndings  EndingDefinition[]   @relation("EndingRequiredClues")

  @@index([historyId])
}

model ConclusionDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String @unique
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  fields ConclusionField[]
}

model ConclusionField {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  conclusionId String
  conclusion   ConclusionDefinition @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  label String
  type  ConclusionFieldType

  options ConclusionOption[]

  @@index([conclusionId])
}

model ConclusionOption {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  fieldId String
  field   ConclusionField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  label String

  @@index([fieldId])
}

model EndingDefinition {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  historyId String
  history   History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  title String

  type EndingType

  imageUrl String?

  conclusionMatches Json
  requiredClues     ClueDefinition[] @relation("EndingRequiredClues")

  summary  String
  epilogue String

  @@index([historyId])
}

// ─── History session (runtime state — full definition snapshot) ───────────────

model HistorySession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  historyId String

  // history snapshot
  title                    String
  subtitle                 String?
  teaser                   String
  opening                  String
  objective                String
  genre                    String
  coverImageUrl            String?
  thumbnailUrl             String?
  estimatedDurationMinutes Int

  status      HistorySessionStatus @default(active)
  startedAt   DateTime             @default(now())
  completedAt DateTime?

  clues            SessionClue[]
  intents          SessionIntent[]
  conclusionFields SessionConclusionField[]
  endingSnapshots  SessionEndingSnapshot[]

  characterStates CharacterSessionState[]
  locationStates  LocationSessionState[]
  objectStates    ObjectSessionState[]

  conclusion SessionConclusion?
  ending     SessionEnding?

  llmCalls LlmCall[]

  @@index([userId])
  @@index([historyId])
}

model SessionClue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clueDefinitionId String

  title       String
  description String
  importance ClueImportance

  discovered   Boolean   @default(false)
  discoveredAt DateTime?

  characterRules              SessionCharacterClueRevealRule[] @relation("CharRuleClue")
  objectRules                 SessionObjectClueRevealRule[]    @relation("ObjRuleClue")
  requiredByCharacterRules    SessionCharacterClueRevealRule[] @relation("CharRuleRequiredClues")
  requiredByObjectRules       SessionObjectClueRevealRule[]    @relation("ObjRuleRequiredClues")
  requiredBySecretStages      SessionSecretRevealStage[]       @relation("SessionSecretStageRequiredClues")
  revealedBySecretStages      SessionSecretRevealStage[]       @relation("SessionSecretStageRevealedClues")
  ambientForLocations         LocationSessionState[]           @relation("SessionLocationAmbientClues")
  revealedAmbientForLocations LocationSessionState[]           @relation("LocationRevealedAmbientClues")
  requiredByEndings           SessionEndingSnapshot[]          @relation("SessionEndingRequiredClues")
  revealedByCharacterStates   CharacterSessionState[]         @relation("CharStateRevealedClues")
  revealedByObjectStates      ObjectSessionState[]            @relation("ObjStateRevealedClues")
  revealedBySecretStates      CharacterSecretSessionState[]   @relation("SecretStateRevealedClues")

  @@index([sessionId])
}

model SessionIntent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  intentDefinitionId String

  description String
  examples    String[] @default([])
  keywords    String[] @default([])

  triggeredByCharacterRules SessionCharacterClueRevealRule[] @relation("CharRuleTriggerIntents")
  triggeredByObjectRules    SessionObjectClueRevealRule[]    @relation("ObjRuleTriggerIntents")
  triggeredBySecretStages   SessionSecretRevealStage[]       @relation("SessionSecretStageTriggerIntents")

  @@index([sessionId])
}

model CharacterSessionState {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  characterDefinitionId String

  name             String
  role             String
  shortDescription String
  imageUrl         String?

  personality   String
  speakingStyle String
  openingLine   String

  publicKnowledge        String[] @default([])
  privateKnowledge       String[] @default([])
  conversationBoundaries String[] @default([])

  conversationSummary String?

  clueRevealRules SessionCharacterClueRevealRule[]
  secrets         CharacterSecretSessionState[]
  revealedClues   SessionClue[]               @relation("CharStateRevealedClues")
  messages        CharacterConversationMessage[]

  @@index([sessionId])
}

model SessionCharacterClueRevealRule {
  id String @id @default(uuid())

  characterStateId String
  characterState   CharacterSessionState @relation(fields: [characterStateId], references: [id], onDelete: Cascade)

  clueId String
  clue   SessionClue @relation("CharRuleClue", fields: [clueId], references: [id], onDelete: Cascade)

  triggerIntents SessionIntent[] @relation("CharRuleTriggerIntents")
  requiredClues  SessionClue[]   @relation("CharRuleRequiredClues")

  revealText       String
  responseGuidance String

  @@index([characterStateId])
  @@index([clueId])
}

model CharacterSecretSessionState {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  characterStateId String
  characterState   CharacterSessionState @relation(fields: [characterStateId], references: [id], onDelete: Cascade)

  secretDefinitionId String

  summary String
  truth   String

  defaultStrategy SecretDefaultStrategy

  currentStageLevel Int @default(0)

  revealStages  SessionSecretRevealStage[]
  revealedClues SessionClue[]              @relation("SecretStateRevealedClues")

  @@index([characterStateId])
}

model SessionSecretRevealStage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  secretStateId String
  secretState   CharacterSecretSessionState @relation(fields: [secretStateId], references: [id], onDelete: Cascade)

  stageDefinitionId String

  level Int

  triggerIntents SessionIntent[] @relation("SessionSecretStageTriggerIntents")
  requiredClues  SessionClue[]   @relation("SessionSecretStageRequiredClues")
  revealsClues   SessionClue[]   @relation("SessionSecretStageRevealedClues")

  behavior             String
  allowedToRevealTruth Boolean

  sampleResponses String[] @default([])

  @@index([secretStateId])
}

model LocationSessionState {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  locationDefinitionId String

  name             String
  shortDescription String
  imageUrl         String?
  initialDescription String

  ambientClues         SessionClue[] @relation("SessionLocationAmbientClues")
  revealedAmbientClues SessionClue[] @relation("LocationRevealedAmbientClues")

  objects ObjectSessionState[]

  visited   Boolean   @default(false)
  visitedAt DateTime?

  @@index([sessionId])
}

model ObjectSessionState {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  locationStateId String?
  locationState   LocationSessionState? @relation(fields: [locationStateId], references: [id], onDelete: SetNull)

  objectDefinitionId String

  name             String
  shortDescription String
  imageUrl         String?
  initialDescription String

  clueRevealRules SessionObjectClueRevealRule[]
  revealedClues   SessionClue[]                 @relation("ObjStateRevealedClues")
  messages        ObjectInteractionMessage[]

  inspected   Boolean   @default(false)
  inspectedAt DateTime?

  @@index([sessionId])
  @@index([locationStateId])
}

model SessionObjectClueRevealRule {
  id String @id @default(uuid())

  objectStateId String
  objectState   ObjectSessionState @relation(fields: [objectStateId], references: [id], onDelete: Cascade)

  clueId String
  clue   SessionClue @relation("ObjRuleClue", fields: [clueId], references: [id], onDelete: Cascade)

  triggerIntents SessionIntent[] @relation("ObjRuleTriggerIntents")
  requiredClues  SessionClue[]   @relation("ObjRuleRequiredClues")

  revealText String

  @@index([objectStateId])
  @@index([clueId])
}

model ObjectInteractionMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  objectStateId String
  objectState   ObjectSessionState @relation(fields: [objectStateId], references: [id], onDelete: Cascade)

  role    InteractionRole
  content String

  @@index([objectStateId])
  @@index([objectStateId, createdAt])
}

model CharacterConversationMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  characterStateId String
  characterState   CharacterSessionState @relation(fields: [characterStateId], references: [id], onDelete: Cascade)

  role    InteractionRole
  content String

  @@index([characterStateId])
  @@index([characterStateId, createdAt])
}

model SessionConclusionField {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  fieldDefinitionId String

  label String
  type  ConclusionFieldType

  options SessionConclusionOption[]
  answers SessionConclusionAnswer[]

  @@index([sessionId])
}

model SessionConclusionOption {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  fieldId String
  field   SessionConclusionField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  optionDefinitionId String

  label String

  answers SessionConclusionAnswer[]

  @@index([fieldId])
}

model SessionConclusion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String @unique
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  submittedAt DateTime

  answers SessionConclusionAnswer[]

  @@index([sessionId])
}

model SessionConclusionAnswer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conclusionId String
  conclusion   SessionConclusion @relation(fields: [conclusionId], references: [id], onDelete: Cascade)

  fieldId String
  field   SessionConclusionField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  optionId String
  option   SessionConclusionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([conclusionId, fieldId])
  @@index([conclusionId])
  @@index([fieldId])
  @@index([optionId])
}

model SessionEndingSnapshot {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  endingDefinitionId String

  title    String
  type     EndingType
  imageUrl String?
  summary  String
  epilogue String

  conclusionMatches Json
  requiredClues     SessionClue[] @relation("SessionEndingRequiredClues")

  chosenBy SessionEnding?

  @@index([sessionId])
}

model SessionEnding {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  sessionId String @unique
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  endingSnapshotId String @unique
  endingSnapshot   SessionEndingSnapshot @relation(fields: [endingSnapshotId], references: [id], onDelete: Cascade)

  score SessionScore?

  @@index([sessionId])
  @@index([endingSnapshotId])
}

model SessionScore {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  sessionEndingId String @unique
  sessionEnding   SessionEnding @relation(fields: [sessionEndingId], references: [id], onDelete: Cascade)

  discoveredClues         Int
  totalClues              Int
  requiredCluesDiscovered Int
  totalRequiredClues      Int
  correctAnswers          Int
  totalAnswers            Int
}

// ─── LLM usage / cost tracking ────────────────────────────────────────────────

model LlmCall {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  sessionId String
  session   HistorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  purpose LlmCallPurpose
  model   String

  promptTokens     Int
  completionTokens Int
  totalTokens      Int

  costUsdNanos BigInt
  latencyMs    Int?

  audioSeconds Int?

  @@index([sessionId])
  @@index([createdAt])
}

// ─── Subscriptions (Stripe) ───────────────────────────────────────────────────

model Plan {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  stripePriceId   String         @unique
  name            String
  creditsPerCycle Int
  interval        String
  active          Boolean        @default(true)

  subscriptions   Subscription[]

  @@index([active])
}

model Subscription {
  id                   String             @id @default(uuid())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId               String?
  plan                 Plan?              @relation(fields: [planId], references: [id])

  stripeCustomerId         String         @unique
  stripeSubscriptionId     String?        @unique
  stripePriceId            String?

  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  creditGrants         CreditGrant[]

  @@index([status])
}

// Idempotency ledger — one row per Stripe invoice we've granted credits for.
model CreditGrant {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())

  subscriptionId   String
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  stripeInvoiceId  String   @unique
  credits          Int
  userId           String

  @@index([subscriptionId])
  @@index([userId])
}
