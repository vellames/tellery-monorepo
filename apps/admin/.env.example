# Local-only admin dashboard. Copy this file to `.env` and fill in the
# production-ready connection string this app should read from.
#
#   cp .env.example .env
#
# `.env` is gitignored and must NEVER be committed.

# Prisma / Postgres connection string used by @prisma/client.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
